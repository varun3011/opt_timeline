generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  optApplication OPTApplication?
  notifications  Notification[]
  aiChats        AIChat[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OPTApplication {
  id                 String    @id @default(cuid())
  userId             String    @unique
  status             OPTStatus @default(PENDING)
  receiptDate        DateTime?
  approvalDate       DateTime?
  optStartDate       DateTime?
  optEndDate         DateTime?
  eadCardReceived    Boolean   @default(false)
  employerName       String?
  employerEin        String?
  jobTitle           String?
  jobStartDate       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stemExtension     StemExtension?
  unemployment      UnemploymentLog[]
  employmentHistory EmploymentHistory[]
}

model EmploymentHistory {
  id               String    @id @default(cuid())
  optApplicationId String
  employerName     String
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  optApplication OPTApplication @relation(fields: [optApplicationId], references: [id], onDelete: Cascade)
}

enum OPTStatus {
  PENDING
  APPROVED
  ACTIVE
  STEM_EXTENSION
  EXPIRED
}

model StemExtension {
  id               String    @id @default(cuid())
  optApplicationId String    @unique
  status           StemStatus @default(PENDING)
  applicationDate  DateTime?
  approvalDate     DateTime?
  stemStartDate    DateTime?
  stemEndDate      DateTime?
  employerEverify  Boolean   @default(false)
  i983SubmittedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  optApplication OPTApplication @relation(fields: [optApplicationId], references: [id], onDelete: Cascade)
}

enum StemStatus {
  NOT_STARTED
  PENDING
  APPROVED
  ACTIVE
  EXPIRED
}

model UnemploymentLog {
  id               String   @id @default(cuid())
  optApplicationId String
  startDate        DateTime
  endDate          DateTime?
  notes            String?
  createdAt        DateTime @default(now())

  optApplication OPTApplication @relation(fields: [optApplicationId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  DEADLINE_REMINDER
  STATUS_UPDATE
  UNEMPLOYMENT_ALERT
  STEM_REMINDER
  GENERAL
}

model AIChat {
  id        String    @id @default(cuid())
  userId    String
  messages  Json      @default("[]")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
